# Local development configuration
# For deployment, these are set via Terraform / the deploy command.

# Vertex AI Configuration (default)
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global

# Alternatively, for Gemini API via Google AI Studio,
# comment out the three lines above and uncomment:
# GEMINI_API_KEY=your-api-key-here

SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# Agent Runtime URL format 
# https://asia-northeast1-aiplatform.googleapis.com/reasoningEngines/v1/projects/834471899683/locations/asia-northeast1/reasoningEngines/2938730698254581760
KNOWLEDGE_AGENT_URL=

