# Local development configuration
# For deployment, these are set via Terraform / the deploy command.

# Vertex AI Configuration (default)
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global

# Alternatively, for Gemini API via Google AI Studio,
# comment out the three lines above and uncomment:
# GEMINI_API_KEY=your-api-key-here

SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# Agent Runtime URL format 
# https://{region}-aiplatform.googleapis.com/v1/projects/{projectid}/locations/{retion}/reasoningEngines/{agent runtime id}
CAA_AGENT_URL=
KNOWLEDGE_AGENT_URL=
T2s_AGENT_URL=
